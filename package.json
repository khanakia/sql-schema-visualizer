{
  "name": "sql-schema-visualizer",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Fast, smooth, free in-browser SQL database schema visualizer. Paste DDL for PostgreSQL, MySQL, SQLite or ANSI SQL and get an interactive ER diagram — no backend, no signup.",
  "keywords": [
    "sql",
    "database",
    "schema",
    "visualizer",
    "er-diagram",
    "erd",
    "postgresql",
    "mysql",
    "sqlite",
    "ddl",
    "react-flow"
  ],
  "license": "MIT",
  "author": "khanakia",
  "homepage": "https://github.com/khanakia/sql-schema-visualizer",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@dagrejs/dagre": "^3.0.0",
    "@tanstack/react-router": "^1.170.4",
    "@xyflow/react": "^12.10.2",
    "html-to-image": "^1.11.13",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/router-plugin": "^1.168.6",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "tailwindcss": "^4.3.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12"
  }
}
