{
  "name": "sql-schema-visualizer",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Fast, smooth, free in-browser SQL database schema visualizer. Monorepo: @sqlviz/core (parser/layout/share), @sqlviz/react (components), and the GitHub Pages app.",
  "keywords": [
    "sql",
    "database",
    "schema",
    "visualizer",
    "er-diagram",
    "erd",
    "postgresql",
    "mysql",
    "sqlite",
    "ddl",
    "react-flow"
  ],
  "license": "MIT",
  "author": "khanakia",
  "homepage": "https://github.com/khanakia/sql-schema-visualizer",
  "scripts": {
    "dev": "pnpm --filter @sqlviz/web dev",
    "test": "pnpm --filter @sqlviz/core test",
    "build:libs": "pnpm --filter @sqlviz/core build && pnpm --filter @sqlviz/react build",
    "build:web": "pnpm --filter @sqlviz/web build",
    "build": "pnpm run build:libs && pnpm run build:web",
    "typecheck": "pnpm -r typecheck",
    "preview": "pnpm --filter @sqlviz/web preview"
  },
  "devDependencies": {
    "vitest": "^4.1.6"
  }
}
