# Copy to .env (gitignored) and fill in. Used by `task deploy:cf`.
#
# Cloudflare API token, account aman@khanakia.com, "Edit Cloudflare
# Workers" template. Create/rotate at:
#   https://dash.cloudflare.com/profile/api-tokens
# Account-scoped, so it deploys to the right account regardless of
# browser login. NEVER commit the real value.
CLOUDFLARE_API_TOKEN=
